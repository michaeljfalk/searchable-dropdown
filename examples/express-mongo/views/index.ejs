<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>LiveSelect — Express + MongoDB (EJS)</title>
  <link rel="stylesheet" href="/dist/liveselect.css">
  <style>
    body { font-family: system-ui, sans-serif; max-width: 560px; margin: 40px auto; padding: 0 16px; }
    h2 { font-size: 1rem; margin-top: 32px; }
    .out { margin-top: 10px; font: 0.85rem ui-monospace, monospace; color: #2563eb; }
    button.go { margin-top: 14px; padding: 9px 16px; border: 0; border-radius: 8px; background: #2563eb; color: #fff; cursor: pointer; }
  </style>
</head>
<body>
  <h1>Customers (live from MongoDB)</h1>
  <p>Type to search the <code>customers</code> collection. No match? Use <b>+ Add</b> to create one.</p>

  <!-- ===== A · Declarative: rendered by the EJS partial, zero inline JS ===== -->
  <h2>A · Declarative (EJS partial + auto-mount)</h2>
  <form id="formA">
    <%- include('_dropdown', {
          name: 'customerId',
          label: 'Customer',
          placeholder: 'Search customers…',
          apiKey: 'customers',
          allowCreate: true,
        }) %>
    <button class="go" type="submit">Submit</button>
  </form>
  <div class="out" id="outA">value: (none)</div>

  <!-- ===== B · Imperative: build it in JS for full control ===== -->
  <h2>B · Imperative (build in JS)</h2>
  <div id="customerPicker"></div>
  <div class="out" id="outB">value: (none)</div>

  <!-- Load once: core, then the optional declarative auto-mount helper. -->
  <script src="/dist/liveselect.js"></script>
  <script src="/dist/liveselect-auto.js"></script>
  <script>
    // The declarative control (A) reports through the bubbling CustomEvent.
    document.getElementById('formA').addEventListener('sdd:change', function (e) {
      document.getElementById('outA').textContent =
        'value: ' + JSON.stringify(e.detail.value) + (e.detail.option ? '  (' + e.detail.option.label + ')' : '');
    });
    document.getElementById('formA').addEventListener('submit', function (e) {
      e.preventDefault();
      alert('Form would submit customerId=' + new FormData(e.target).get('customerId'));
    });

    // The imperative control (B) — same data source, built by hand.
    var api = LiveSelect.remoteSource({ baseUrl: '/api/dropdown', key: 'customers', create: true });
    new LiveSelect('#customerPicker', {
      name: 'customerId2',
      label: 'Customer',
      placeholder: 'Search customers…',
      source: api.source,
      resolve: api.resolve,
      allowCreate: true,
      onCreate: api.onCreate,
      createLabel: function (q) { return '+ Add customer “' + q + '”'; },
      onChange: function (value, option) {
        document.getElementById('outB').textContent =
          'value: ' + JSON.stringify(value) + (option ? '  (' + option.label + ')' : '');
      },
    });
  </script>
</body>
</html>
